# ──────────────────────────────────────────────────
# DATABASE (PostgreSQL — use Neon free tier)
# Get it at: https://neon.tech
# ──────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ──────────────────────────────────────────────────
# NEXTAUTH
# NEXTAUTH_URL = your production domain on Vercel
# NEXTAUTH_SECRET = run: openssl rand -base64 32
# ──────────────────────────────────────────────────
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="generate-a-random-32-char-secret"

# ──────────────────────────────────────────────────
# EMAIL / OTP (required for 2-step login with OTP)
# Works with Gmail, Outlook, SendGrid SMTP, etc.
# Gmail: use an App Password (not your account password)
#   Guide: myaccount.google.com/apppasswords
# If left blank, login falls back to password-only (no OTP).
# ──────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="your-email@gmail.com"

# ──────────────────────────────────────────────────
# AI PROVIDER KEYS (at least one required)
# ──────────────────────────────────────────────────
GOOGLE_GENAI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
