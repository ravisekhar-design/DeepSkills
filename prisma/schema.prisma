// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?              @unique
  password            String?
  image               String?
  accounts            Account[]
  sessions            Session[]
  agents              Agent[]
  skills              Skill[]
  settings            SystemSettings?
  chatThreads         ChatThread[]
  databaseConnections DatabaseConnection[]
  fileFolders         FileFolder[]
  fileRecords         FileRecord[]
  dashboards          Dashboard[]
  dataPrepFlows       DataPrepFlow[]
  preparedDatasets    PreparedDataset[]
  semanticModels      SemanticModel[]
  worksheets          Worksheet[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Agent {
  id          String   @id @default(cuid())
  userId      String
  name        String
  persona     String
  objectives  String
  parameters  String   // stored as JSON string
  skills      String   // stored as JSON string array of IDs
  databases   String?  // stored as JSON string array of DatabaseConnection IDs
  fileFolders String?  // stored as JSON string array of FileFolder IDs (entire folder)
  files       String?  // stored as JSON string array of individual FileRecord IDs
  status      String   @default("active")
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Skill {
  id          String   @id // Use string as ID for consistency with existing skills
  userId      String?
  name        String
  description String
  category    String
  inputs      String   // stored as JSON string array
  enabled     Boolean  @default(true)
  isCustom    Boolean  @default(false)
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SystemSettings {
  id               String  @id @default(cuid())
  userId           String  @unique
  modelMapping     String  // stored as JSON string
  providers        String  // stored as JSON string
  globalKillSwitch Boolean @default(false)
  apiKeys          String? // stored as JSON string

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatThread {
  id        String   @id @default(cuid())
  userId    String
  agentId   String
  messages  String   // stored as JSON string array
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  details   String?  // Stored as JSON string
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([level])
}

model DatabaseConnection {
  id               String   @id @default(cuid())
  userId           String
  name             String
  type             String   // 'postgresql' | 'mysql' | 'mssql' | 'mongodb' | 'oracle' | 'sqlite'
  host             String?
  port             Int?
  database         String?
  username         String?
  password         String?
  connectionString String?
  ssl              Boolean  @default(false)
  readOnly         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FileFolder {
  id        String       @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  files     FileRecord[]

  @@index([userId])
}

model FileRecord {
  id          String      @id @default(cuid())
  userId      String
  folderId    String
  name        String
  mimeType    String      @default("text/plain")
  size        Int         @default(0)
  content     String?     @db.Text  // null when file is stored as chunks
  totalChunks Int         @default(0)
  createdAt   DateTime    @default(now())
  folder      FileFolder  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks      FileChunk[]

  @@index([userId])
  @@index([folderId])
}

model FileChunk {
  id      String     @id @default(cuid())
  fileId  String
  idx     Int
  content String     @db.Text
  file    FileRecord @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([fileId, idx])
}

model Dashboard {
  id               String            @id @default(cuid())
  userId           String
  name             String
  description      String?
  boundSourceType  String?           // 'database' | 'file'
  boundSourceId    String?           // connectionId or fileId
  boundSourceName  String?           // display name
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets          DashboardWidget[]

  @@index([userId])
}

model DashboardWidget {
  id             String    @id @default(cuid())
  dashboardId    String
  title          String
  chartType      String    // 'bar' | 'line' | 'area' | 'pie'
  chartConfig    String    @db.Text // JSON: { xKey, series, data }
  dataSourceType String    // 'database' | 'file'
  dataSourceId   String    // connectionId or fileId
  dataSourceName String    @default("") // display name
  dataQuery      String?   @db.Text // SQL for database charts
  prompt         String    @db.Text
  gridW          Int       @default(1) // 1=half, 2=full width
  createdAt      DateTime  @default(now())
  dashboard      Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
}

model DataPrepFlow {
  id          String            @id @default(cuid())
  userId      String
  name        String
  description String?
  steps       String            @db.Text  // JSON: PrepStep[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  datasets    PreparedDataset[]

  @@index([userId])
}

model PreparedDataset {
  id          String       @id @default(cuid())
  userId      String
  flowId      String
  name        String
  description String?
  schema      String       @db.Text  // JSON: ColumnSchema[]
  sampleRows  String       @db.Text  // JSON: first 200 rows
  rowCount    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  flow        DataPrepFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([flowId])
}

model SemanticModel {
  id           String      @id @default(cuid())
  userId       String
  name         String
  description  String?
  // Source binding
  sourceType   String      // 'database' | 'prepared_dataset' | 'file'
  sourceId     String
  sourceName   String
  sourceTable  String?     // optional table name when sourceType=database
  sourceSql    String?     @db.Text // optional custom SQL when sourceType=database
  // JSON-encoded
  fields       String      @db.Text  // FieldDef[]
  calculations String      @db.Text  // CalcField[]
  hierarchies  String?     @db.Text  // Hierarchy[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  worksheets   Worksheet[]

  @@index([userId])
}

model Worksheet {
  id          String         @id @default(cuid())
  userId      String
  modelId     String?
  name        String
  description String?
  // WorksheetConfig — chart type, shelves, marks, options
  config      String         @db.Text
  // Cached preview rows (JSON)
  cachedData  String?        @db.Text
  cachedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  model       SemanticModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([modelId])
}

model LoginOtp {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}
