// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?              @unique
  password            String?
  image               String?
  accounts            Account[]
  sessions            Session[]
  agents              Agent[]
  skills              Skill[]
  settings            SystemSettings?
  chatThreads         ChatThread[]
  databaseConnections DatabaseConnection[]
  fileFolders         FileFolder[]
  fileRecords         FileRecord[]
  dashboards          Dashboard[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Agent {
  id          String   @id @default(cuid())
  userId      String
  name        String
  persona     String
  objectives  String
  parameters  String   // stored as JSON string
  skills      String   // stored as JSON string array of IDs
  databases   String?  // stored as JSON string array of DatabaseConnection IDs
  fileFolders String?  // stored as JSON string array of FileFolder IDs
  status      String   @default("active")
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Skill {
  id          String   @id // Use string as ID for consistency with existing skills
  userId      String?
  name        String
  description String
  category    String
  inputs      String   // stored as JSON string array
  enabled     Boolean  @default(true)
  isCustom    Boolean  @default(false)
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id               String  @id @default(cuid())
  userId           String  @unique
  modelMapping     String  // stored as JSON string
  providers        String  // stored as JSON string
  globalKillSwitch Boolean @default(false)
  apiKeys          String? // stored as JSON string

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatThread {
  id        String   @id @default(cuid())
  userId    String
  agentId   String
  messages  String   // stored as JSON string array
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  details   String?  // Stored as JSON string
  createdAt DateTime @default(now())
}

model DatabaseConnection {
  id               String   @id @default(cuid())
  userId           String
  name             String
  type             String   // 'postgresql' | 'mysql' | 'mssql' | 'mongodb' | 'oracle' | 'sqlite'
  host             String?
  port             Int?
  database         String?
  username         String?
  password         String?
  connectionString String?
  ssl              Boolean  @default(false)
  readOnly         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FileFolder {
  id        String       @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  files     FileRecord[]
}

model FileRecord {
  id        String     @id @default(cuid())
  userId    String
  folderId  String
  name      String
  mimeType  String     @default("text/plain")
  size      Int        @default(0)
  content   String     @db.Text
  createdAt DateTime   @default(now())
  folder    FileFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Dashboard {
  id        String            @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets   DashboardWidget[]
}

model DashboardWidget {
  id             String    @id @default(cuid())
  dashboardId    String
  title          String
  chartType      String    // 'bar' | 'line' | 'area' | 'pie'
  chartConfig    String    @db.Text // JSON: { xKey, series, data }
  dataSourceType String    // 'database' | 'file'
  dataSourceId   String    // connectionId or fileId
  dataSourceName String    @default("") // display name
  dataQuery      String?   @db.Text // SQL for database charts
  prompt         String    @db.Text
  gridW          Int       @default(1) // 1=half, 2=full width
  createdAt      DateTime  @default(now())
  dashboard      Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
}
